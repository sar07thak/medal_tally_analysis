{"id":-1,"name":"FROM_FILE","userId":-1,"createdAt":"","updatedAt":"","content":{"items":[{"uid":"VwkgLPJLJp","position":{"x":100,"y":30},"sizes":{"width":400,"height":234.1875},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"codeBlock","attrs":{"language":"python","wrapCode":false},"content":[{"type":"text","text":"def preprocess(df , region_df) :\n    df = df[df['Season'] == 'Summer']\n    df = df.merge( region_df , on='NOC' , how='left')\n    df = df.drop_duplicates()\n    df = pd.concat([df,pd.get_dummies(df['Medal'])],axis=1)\n\n    return df "}]}]},"nodeType":"block"},{"uid":"bPvrzlmyEy","position":{"x":500,"y":320},"sizes":{"width":380,"height":307.6875},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"App.py  "}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"-> import preprocess fumction to show all the data present "}]},{"type":"codeBlock","attrs":{"language":"python","wrapCode":false},"content":[{"type":"text","text":"df = preprocessor.preprocess(df , region_df)"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"-> import medal_tally function to show medals "}]},{"type":"codeBlock","attrs":{"language":"python","wrapCode":false},"content":[{"type":"text","text":"medal_tally = helper.medal_tally(df)"}]}]},"nodeType":"block"},{"uid":"aYuISibPF7","position":{"x":0,"y":530},"sizes":{"width":400,"height":251.6875},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"codeBlock","attrs":{"language":null,"wrapCode":false},"content":[{"type":"text","text":"\ndef medal_tally( df   ) : \n    # update the problem and make sure it count as 1 medal \n    medal = df.drop_duplicates(subset=['NOC','Games','Year','Season','City','Sport','Event','Medal','region','notes','Bronze','Gold','Silver'])\n\n    medal = medal.groupby('region')[['Gold','Silver','Bronze']].sum().sort_values( by ='Gold' , ascending = False ).reset_index() \n    medal['total'] = medal['Gold'] + medal['Silver'] + medal['Bronze']\n    return medal"}]}]},"nodeType":"block"}],"configs":{"centerX":175.1502032633084,"centerY":29.759105898332677,"zoomLevel":0.7360233378410337},"arrowData":{"arrowsMap":{},"pointsMap":{},"edgesMap":{"edge-VwkgLPJLJp-VwkgLPJLJp-bottom-bPvrzlmyEy-bPvrzlmyEy-top":{"uid":"edge-VwkgLPJLJp-VwkgLPJLJp-bottom-bPvrzlmyEy-bPvrzlmyEy-top","fromNodeId":"VwkgLPJLJp","fromHandleId":"VwkgLPJLJp-bottom","toNodeId":"bPvrzlmyEy","toHandleId":"bPvrzlmyEy-top","direction":"ft","selectable":true,"type":"solid","content":{"label":""}},"edge-aYuISibPF7-aYuISibPF7-right-bPvrzlmyEy-bPvrzlmyEy-left":{"uid":"edge-aYuISibPF7-aYuISibPF7-right-bPvrzlmyEy-bPvrzlmyEy-left","fromNodeId":"aYuISibPF7","fromHandleId":"aYuISibPF7-right","toNodeId":"bPvrzlmyEy","toHandleId":"bPvrzlmyEy-left","direction":"ft","selectable":true,"type":"solid","content":{"label":""}}}}}}